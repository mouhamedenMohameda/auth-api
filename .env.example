# ─── auth-api — configuration ────────────────────────────────────────────────

# Active l'authentification (toujours true en prod). Si false, l'app est ouverte.
AUTH_REQUIRED=true

# Secret JWT (32+ caractères aléatoires). Génère avec :
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=remplace_moi_par_un_secret_de_32_caracteres_min

# Base de données. Par défaut SQLite local. Pour Postgres :
#   DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname
# DATABASE_URL=sqlite:///./data/auth-api.db

# Origines autorisées (CORS), séparées par virgule.
# Mets ici TES domaines front-end (Débloque-moi, LectureAI...).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://bac.rim.dev,https://lecture.rim.dev

# ─── Clés S2S (server-to-server) ─────────────────────────────────────────────
# Format : app_id:secret,app_id2:secret2
# Le secret doit faire ≥ 16 caractères. Chaque app consommatrice utilise SA clé
# via le header X-Api-Key pour appeler /s2s/wallet/debit etc.
# Génère un secret avec :
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
S2S_API_KEYS=debloquemoi:REMPLACE_PAR_SECRET_32_CHARS,lecturai:REMPLACE_AUSSI

# ─── Compte admin désigné (premier compte qui devient admin) ─────────────────
ADMIN_EMAIL=mohameda.mouhameden@gmail.com

# ─── Crédits & pricing ───────────────────────────────────────────────────────
# Bonus d'inscription (en unités portefeuille). 0 = pas de bonus.
# Par défaut : 5 × MRU_WALLET_MICRO = ~5 MRU offert.
# CREDITS_REGISTRATION_BONUS=

# Validité du bonus initial (jours).
CREDITS_REGISTRATION_VALIDITY_DAYS=365

# Validité étendue à chaque top-up approuvé (jours).
CREDITS_TOPUP_APPROVE_EXTEND_DAYS=90

# ─── MRU / pricing ───────────────────────────────────────────────────────────
# Taux de change USD → MRU
MRU_PER_USD=40

# Marge commerciale appliquée au coût provider (1.5 = +50%, 2 = double)
MARGIN_MULTIPLIER=2

# Granularité du portefeuille : 1 MRU affiché = MRU_WALLET_MICRO unités stockées.
# Plus élevé = précision plus fine (mais entiers plus gros). 1000 est un bon défaut.
MRU_WALLET_MICRO=1000

# ─── E-mails legacy (re-création de compte gracieux) ─────────────────────────
# Liste d'e-mails séparés par virgule pour lesquels un message spécial est affiché
# au login si le compte n'existe pas (utile après un reset DB).
LEGACY_REREGISTER_EMAILS=
